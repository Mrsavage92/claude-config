{
  "$schema": "per-iter-delta-handoff",
  "description": "Schema for the per-iter critique response. Used by parse-handoff.sh per-iter-delta.",
  "required": [
    "iteration",
    "route",
    "verdict",
    "ssim_estimate",
    "visible_delta_verdict",
    "checklist_status_change",
    "tool_use_id_for_pre_screenshot",
    "tool_use_id_for_post_screenshot"
  ],
  "enums": {
    "verdict": ["KEEP", "VOID", "REVERT"]
  },
  "field_types": {
    "iteration": "integer",
    "route": "string",
    "verdict": "string (enum)",
    "ssim_estimate": "float 0.0–1.0",
    "visible_delta_verdict": "float 0.0–5.0",
    "checklist_status_change": "array of {rule, was, now}",
    "tool_use_id_for_pre_screenshot": "toolu_ID",
    "tool_use_id_for_post_screenshot": "toolu_ID"
  }
}
