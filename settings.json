{
  "env": {
    "CLOUDFLARE_ACCOUNT_ID": "e15a9c89ed8482988bd304bef49ceb07",
    "CLOUDFLARE_EMAIL": "adamsavage6@hotmail.co.uk",
    "NOTION_INTERNAL_TOKEN": "ROTATE_AT_NOTION_THEN_PASTE_NEW_TOKEN_HERE",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch",
      "WebSearch",
      "Skill",
      "mcp__*"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "C:\\Users\\Adam",
      "C:\\Users\\Adam\\Documents\\Git\\claude-config",
      "C:\\Users\\Adam\\.claude\\skills",
      "C:\\Users\\Adam\\.claude\\projects",
      "\\\\wsl.localhost\\Ubuntu\\home\\adam"
    ]
  },
  "enabledMcpjsonServers": [
    "notion",
    "magic",
    "cloudflare",
    "vercel",
    "supabase",
    "lucid"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|MultiEdit|AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\pretool-router.ps1\"",
            "timeout": 8000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\build-context-inject.ps1\"",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\log-tools.ps1\"",
            "timeout": 3000,
            "async": true
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\start-dev-server.ps1\"",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\safe-session-start.ps1\"",
            "timeout": 15000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\safe-session-stop.ps1\"",
            "timeout": 15000,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": false,
    "stripe@claude-plugins-official": true,
    "adspirer-ads-agent@claude-plugins-official": false,
    "autofix-bot@claude-plugins-official": false,
    "supabase@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
