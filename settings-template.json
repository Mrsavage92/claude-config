{
  "env": {
    "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT_HERE",
    "CLOUDFLARE_ACCOUNT_ID": "YOUR_CLOUDFLARE_ACCOUNT_ID",
    "CLOUDFLARE_EMAIL": "YOUR_CLOUDFLARE_EMAIL"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch",
      "WebSearch",
      "Skill",
      "mcp__*",
      "Read(//c/Users/Adam/Documents/Projects/audit-genius/src/pages/**)",
      "Edit(~/.claude/skills/shared/**)"
    ],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "C:\\Users\\Adam\\.claude\\skills\\market-report-pdf",
      "C:\\Users\\Adam\\Documents\\Claude",
      "C:\\Users\\Adam\\.claude\\skills",
      "C:\\Users\\Adam\\.claude\\commands",
      "C:\\Users\\Adam\\.claude",
      "C:\\Users\\Adam\\.claude\\skills\\shared"
    ]
  },
  "enabledMcpjsonServers": [
    "notion",
    "magic",
    "cloudflare",
    "vercel",
    "supabase"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\gateguard.ps1\"",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\config-protection.ps1\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\build-context-inject.ps1\"",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\log-tools.ps1\"",
            "async": true
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -File \"%USERPROFILE%\\.claude\\hooks\\start-dev-server.ps1\"",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\safe-session-start.ps1\"",
            "timeout": 15000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NonInteractive -ExecutionPolicy Bypass -File \"%USERPROFILE%\\.claude\\hooks\\safe-session-stop.ps1\"",
            "timeout": 15000,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "github@claude-plugins-official": false,
    "stripe@claude-plugins-official": false,
    "adspirer-ads-agent@claude-plugins-official": false,
    "autofix-bot@claude-plugins-official": false,
    "supabase@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
